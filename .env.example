# Felix — environment variables
# Copy to .env and fill in values. All variables use the FLX_ prefix
# unless noted otherwise.

# ---------------------------------------------------------------------------
# LLM provider (pick one)
# ---------------------------------------------------------------------------

# Mistral API
FLX_LLM_API_KEY=your_mistral_api_key
# FLX_LLM_MODEL=mistral-small-latest   # default: Qwen/Qwen2.5-7B-Instruct-Turbo

# Together AI (also accepted as TOGETHER_API_KEY)
# TOGETHER_API_KEY=your_together_key
# FLX_LLM_BASE_URL=https://api.together.xyz/v1
# FLX_LLM_MODEL=Qwen/Qwen2.5-7B-Instruct-Turbo

# LM Studio (auto-detected at localhost:1234 if no other provider is set)
# FLX_LLM_BASE_URL=http://localhost:1234/v1
# FLX_LLM_MODEL=qwen2.5-7b-instruct

# ---------------------------------------------------------------------------
# Neo4j (matches docker-compose.yml defaults)
# ---------------------------------------------------------------------------
FLX_NEO4J_URI=bolt://localhost:7687
FLX_NEO4J_USER=neo4j
FLX_NEO4J_PASSWORD=felixpassword   # change this in any shared/prod environment

# ---------------------------------------------------------------------------
# ChromaDB
# ---------------------------------------------------------------------------
FLX_CHROMA_PATH=chroma_data

# ---------------------------------------------------------------------------
# Observability (optional)
# ---------------------------------------------------------------------------
# LOGFIRE_TOKEN=your_logfire_token
